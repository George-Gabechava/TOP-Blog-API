# Backend API URL (required)
# VITE_BACKEND_URL=https://your-backend.up.railway.app

# Personal site URL (optional)
# Set this to your personal website URL to show a home logo in the header.
# Leave empty or unset if not needed (e.g. if you cloned this repo and don't want a link to someone else's site).
# VITE_PERSONAL_SITE_URL=https://YourPersonalSite.com
